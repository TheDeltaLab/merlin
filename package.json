{
  "name": "@thedeltalab/merlin",
  "version": "1.6.0",
  "description": "CLI tool for Infrastructure as Code deployment and management",
  "type": "module",
  "bin": {
    "merlin": "./dist/merlin.js"
  },
  "exports": {
    ".": "./dist/merlin.js",
    "./runtime.js": "./dist/runtime.js",
    "./init.js": "./dist/init.js",
    "./deployer.js": "./dist/deployer.js"
  },
  "files": [
    "dist",
    "shared-resource",
    "shared-k8s-resource"
  ],
  "scripts": {
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "build": "tsup && chmod +x dist/merlin.js",
    "build:full": "pnpm build && ([ -d .merlin ] && ([ -d .merlin/node_modules ] || (cd .merlin && pnpm install)) && cd .merlin && pnpm build || true)",
    "prepublishOnly": "pnpm build && pnpm test",
    "postinstall": "[ -f dist/merlin.js ] && chmod +x dist/merlin.js || true",
    "link:global": "pnpm build && node scripts/check-global-conflicts.js && pnpm link --global",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/merlin.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/thedeltalab/merlin.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "commander": "^14.0.2",
    "execa": "^9.6.1",
    "js-yaml": "^4.1.1",
    "yaml": "^2.8.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.18.0",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
